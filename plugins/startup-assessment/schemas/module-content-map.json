{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "module-content-map",
  "description": "Maps submission content and external research to each active module. Produced by module-mapper. Consumed by scorer.",
  "type": "object",
  "required": ["company_name", "modules"],
  "properties": {
    "company_name": {"type": "string"},
    "modules": {
      "type": "array",
      "description": "One entry per active module in the confirmed framework.",
      "items": {
        "type": "object",
        "required": ["module_id", "module_name", "domain_id", "submission_content", "research_content", "content_status"],
        "properties": {
          "module_id": {"type": "string"},
          "module_name": {"type": "string"},
          "domain_id": {"type": "integer"},
          "submission_content": {
            "type": "object",
            "description": "Content extracted from the submission document for this module.",
            "properties": {
              "present": {"type": "boolean"},
              "content_summary": {"type": "string", "description": "Brief summary of what the submission says about this module."},
              "source_slides_or_sections": {"type": "array", "items": {"type": "string"}},
              "content_fragments": {"type": "array", "items": {"type": "string"}, "description": "Direct content fragments from submission, clearly attributed."}
            }
          },
          "research_content": {
            "type": "object",
            "description": "External research content retrieved for this module.",
            "properties": {
              "present": {"type": "boolean"},
              "content_summary": {"type": "string"},
              "sources": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "source_id": {"type": "string", "description": "Reference ID linking to research-log entry."},
                    "content_fragment": {"type": "string"},
                    "confidence_level": {"type": "string", "enum": ["high", "medium", "low", "unverifiable"]}
                  }
                }
              }
            }
          },
          "content_status": {
            "type": "string",
            "enum": ["present-submission-only", "present-research-only", "present-both", "absent-externally-resolvable", "absent-unresolvable", "present-conflicting"],
            "description": "Combined content availability status for this module."
          },
          "conflict_flags": {
            "type": "array",
            "description": "Flags where submission content and research content conflict.",
            "items": {
              "type": "object",
              "properties": {
                "dimension": {"type": "string"},
                "submission_claim": {"type": "string"},
                "research_finding": {"type": "string"},
                "source_id": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
